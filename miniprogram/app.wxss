page {
  background: #f6f7fb;
  color: #1f2937;
  font-size: 32rpx;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx 64rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.primary-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.secondary-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 30rpx;
}
