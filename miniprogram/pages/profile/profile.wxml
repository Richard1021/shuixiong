<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar" wx:if="{{userInfo}}">
      <image src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '小宝贝'}}</text>
      <text class="userid">ID: {{userId || '等待登录'}}</text>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-section">
    <text class="section-title">学习统计</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.studyDays}}</text>
        <text class="stat-label">学习天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.readCount}}</text>
        <text class="stat-label">跟读次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.stars}}</text>
        <text class="stat-label">获得星星</text>
      </view>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="settings-section">
    <text class="section-title">设置</text>
    <view class="settings-list">
      <view class="settings-item" bindtap="goToSettings">
        <text class="settings-label">通用设置</text>
        <text class="settings-arrow">›</text>
      </view>
      <view class="settings-item" bindtap="goToAbout">
        <text class="settings-label">关于我们</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToHome">
      <text class="nav-icon">🏠</text>
      <text class="nav-text">首页</text>
    </view>
    <view class="nav-item active">
      <text class="nav-icon">👤</text>
      <text class="nav-text">我的</text>
    </view>
  </view>
</view>
