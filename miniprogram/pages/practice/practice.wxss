.practice-page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  padding: 40rpx 28rpx 72rpx;
  background: linear-gradient(180deg, #fff7d6 0%, #ffe8ae 45%, #ffd98d 100%);
}

.tone-golden {
  background: linear-gradient(180deg, #fff4d8 0%, #ffe1a0 48%, #ffc86f 100%);
}

.sky-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0));
}

.sun-glow {
  position: absolute;
  top: 42rpx;
  right: 48rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 244, 168, 0.95) 0%, rgba(255, 244, 168, 0) 70%);
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  filter: blur(2rpx);
}

.cloud-left {
  top: 90rpx;
  left: 34rpx;
  width: 180rpx;
  height: 72rpx;
}

.cloud-right {
  top: 150rpx;
  right: 40rpx;
  width: 220rpx;
  height: 84rpx;
}

.sparkle,
.rainbow {
  position: absolute;
  font-size: 36rpx;
}

.sparkle-a {
  top: 220rpx;
  left: 90rpx;
}

.sparkle-b {
  top: 260rpx;
  right: 110rpx;
}

.rainbow {
  top: 220rpx;
  right: 60rpx;
  font-size: 44rpx;
}

.top-badge {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #8a6121;
  font-size: 24rpx;
}

.storybook-card {
  position: relative;
  margin-top: 80rpx;
}

.book-cover {
  position: relative;
  min-height: 780rpx;
  border-radius: 48rpx;
  padding: 42rpx;
  background: linear-gradient(180deg, #fffef8 0%, #fff5d8 100%);
  box-shadow: 0 28rpx 64rpx rgba(163, 101, 12, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.book-ring {
  position: absolute;
  top: 42rpx;
  left: 42rpx;
  right: 42rpx;
  bottom: 42rpx;
  border: 6rpx dashed #f3d08b;
  border-radius: 40rpx;
}

.cover-sticker {
  position: absolute;
  top: 54rpx;
  right: 58rpx;
  font-size: 42rpx;
  z-index: 2;
}

.cover-image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  min-height: 696rpx;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(122, 85, 29, 0.14);
}

.cover-fallback {
  position: relative;
  z-index: 1;
  display: flex;
  width: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.book-emoji {
  position: relative;
  font-size: 156rpx;
}

.book-title {
  position: relative;
  margin-top: 36rpx;
  font-size: 56rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #6c4616;
}

.book-subtitle {
  position: relative;
  margin-top: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #8a6121;
}

.hint-bubble {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: -56rpx auto 0;
  width: 84%;
  padding: 24rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(115, 77, 17, 0.12);
}

.hint-icon {
  font-size: 40rpx;
}

.hint-wrap {
  flex: 1;
}

.hint-text {
  font-size: 28rpx;
  color: #7a551d;
}

.progress-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b08953;
}

.practice-panel {
  position: relative;
  margin-top: 40rpx;
  padding: 32rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(115, 77, 17, 0.12);
  text-align: center;
}

.practice-target {
  font-size: 48rpx;
  font-weight: 700;
  color: #6c4616;
}

.practice-hint {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #8a6121;
}

.practice-button {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffbf57 0%, #f59e0b 100%);
  color: #fff;
  font-size: 30rpx;
}

.practice-button.stop {
  background: linear-gradient(180deg, #fb7185 0%, #ef4444 100%);
}

.practice-status {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: #8a6121;
}

.practice-status.success {
  color: #15803d;
}

.footer-stars {
  margin-top: 88rpx;
  text-align: center;
  font-size: 40rpx;
  letter-spacing: 18rpx;
  color: rgba(255, 255, 255, 0.9);
}

.error-note {
  margin-top: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8a6121;
}

.floating-book {
  animation: floatBook 3.6s ease-in-out infinite;
}

.floating-bubble {
  animation: floatBubble 2.8s ease-in-out infinite;
}

@keyframes floatBook {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-14rpx);
  }
}

@keyframes floatBubble {
  0%,
  100% {
    transform: translateY(0) scale(1);
  }

  50% {
    transform: translateY(-8rpx) scale(1.01);
  }
}
