<view class="container home-page">
  <view class="card current-child-card">
    <view class="label">当前孩子</view>
    <view class="value">{{currentChild.nickname || '未选择孩子'}}</view>
    <view wx:if="{{currentChild.currentStage}}" class="meta">阶段：{{currentChild.currentStage}}</view>
    <view class="switch-link" bindtap="handleManageChild">切换/新增孩子</view>
  </view>

  <view class="card start-card">
    <view class="title">开始今天陪练</view>
    <view class="description">确认孩子后，一键进入练习。</view>
    <button class="primary-button" loading="{{loading}}" bindtap="handleStart">开始今天陪练</button>
  </view>
</view>
