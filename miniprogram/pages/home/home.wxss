.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.current-child-card .label {
  font-size: 24rpx;
  color: #6b7280;
}

.current-child-card .value {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 600;
}

.current-child-card .meta {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.switch-link {
  margin-top: 20rpx;
  color: #2563eb;
  font-size: 28rpx;
}

.start-card .title {
  font-size: 40rpx;
  font-weight: 600;
}

.start-card .description {
  margin: 16rpx 0 32rpx;
  color: #6b7280;
  font-size: 28rpx;
}
